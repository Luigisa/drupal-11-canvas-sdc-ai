{#
/**
 * @file
 * Layout de página: regiones alineadas con museothyssen.info.yml.
 */
#}
<div class="layout-page flex min-h-screen flex-col bg-gradient-to-b from-slate-50 to-slate-100 font-sans text-slate-900 antialiased dark:from-slate-950 dark:to-slate-900 dark:text-slate-100">
  {{ page.page_top }}
  <header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/95 shadow-sm backdrop-blur-md dark:border-slate-700/80 dark:bg-slate-950/90" role="banner">
    <div class="mx-auto max-w-6xl px-4 py-3 sm:py-4 lg:px-6">
      {{ page.header }}
    </div>
  </header>
  {% if page.primary_menu %}
    <div class="border-b border-slate-800 bg-gradient-to-r from-slate-900 via-slate-900 to-slate-800 text-slate-100 shadow-inner dark:border-slate-950 dark:from-slate-950 dark:via-slate-950 dark:to-slate-900">
      <div class="mx-auto max-w-6xl px-4 lg:px-6">
        {{ page.primary_menu }}
      </div>
    </div>
  {% endif %}
  {% if page.highlighted %}
    <div class="mx-auto w-full max-w-6xl px-4 pt-4 lg:px-6">
      {{ page.highlighted }}
    </div>
  {% endif %}
  <main class="mx-auto flex w-full max-w-6xl flex-1 flex-col gap-8 px-4 py-8 lg:flex-row lg:gap-10 lg:px-6 lg:py-12" role="main">
    <a id="main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-slate-900 focus:px-4 focus:py-3 focus:text-sm focus:font-medium focus:text-white focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-teal-400 focus:ring-offset-2 dark:focus:bg-white dark:focus:text-slate-900" tabindex="-1">{{ 'Skip to main content'|t }}</a>
    <div class="layout-content min-w-0 flex-1">
      {{ page.content }}
    </div>
    {% if page.sidebar %}
      <aside class="layout-sidebar w-full shrink-0 lg:w-72 xl:w-80" role="complementary">
        <div class="rounded-2xl border border-slate-200/80 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900">
          {{ page.sidebar }}
        </div>
      </aside>
    {% endif %}
  </main>
  {% if page.footer %}
    <footer class="mt-auto border-t border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-950" role="contentinfo">
      <div class="mx-auto max-w-6xl px-4 py-12 text-slate-600 lg:px-6 dark:text-slate-300">
        {{ page.footer }}
      </div>
      <div class="border-t border-slate-200/90 bg-slate-50 py-4 text-center text-xs text-slate-500 dark:border-slate-800 dark:bg-slate-900/80 dark:text-slate-400">
        <p class="m-0">
          © {{ current_year }} {{ site_name }}. {{ 'All rights reserved.'|t }}
        </p>
      </div>
    </footer>
  {% endif %}
  {{ page.page_bottom }}
</div>
