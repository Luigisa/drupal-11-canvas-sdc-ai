{
  "name": "museothyssen",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "postinstall": "uebertool",
    "dev": "vite",
    "watch": "vite",
    "build": "vite build && bun scripts/postbuild.mjs",
    "typecheck": "tsc --noEmit",
    "storybook": "STORYBOOK=true storybook dev -p 6006 --no-open --host 0.0.0.0",
    "front:dev": "concurrently -k -n vite,storybook -c blue,magenta \"bun run dev\" \"STORYBOOK=true bun run storybook\"",
    "build-storybook": "storybook build",
    "storybook:typecheck": "tsc --noEmit -p .storybook/tsconfig.json"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/html-vite": "^10.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "@ueberbit/vite-plugin-drupal": "^0.8.1",
    "concurrently": "^9.2.1",
    "storybook": "^10.4.0",
    "storybook-addon-sdc": "^0.22.19",
    "tailwindcss": "^4",
    "twing": "^7.3.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-twing-drupal": "^1.1.2"
  }
}
