{#
/**
 * @file
 * Componente SDC de ejemplo: museothyssen:hello
 *
 * Imagen vía canvas:image (@see Canvas SDC — Images).
 */
#}
<div{{ attributes.addClass('museothyssen-hello rounded-2xl border border-slate-200/80 bg-white p-6 shadow-sm ring-1 ring-slate-900/5') }}>
  {% if image %}
    <figure class="museothyssen-hello__media mb-4 overflow-hidden rounded-xl">
      {% if image is iterable and (
        image['#theme'] is defined
        or image['#type'] is defined
        or image['#markup'] is defined
        or image['#lazy_builder'] is defined
      ) %}
        {# Render array (Media, formatters de imagen, responsive_image, etc.). #}
        <div class="museothyssen-hello__image-build [&_img]:h-auto [&_img]:w-full [&_img]:object-cover">
          {{ image }}
        </div>
      {% elseif image.src is defined %}
        {% include 'canvas:image' with image|merge({
          alt: image.alt|default(title|default('')),
          loading: image.loading|default('lazy'),
          sizes: image.sizes|default('(max-width: 768px) 100vw, min(42rem, 100vw)'),
          class: image.class|default('museothyssen-hello__img h-auto w-full object-cover'),
          attributes: image.attributes is defined ? image.attributes : create_attribute({}),
        })|filter((value) => value is not null) only %}
      {% else %}
        {# URL string u objeto sin clave src explícita en Twig: tratar como src. #}
        {% include 'canvas:image' with {
          src: image,
          alt: title|default(''),
          loading: 'lazy',
          sizes: '(max-width: 768px) 100vw, min(42rem, 100vw)',
          class: 'museothyssen-hello__img h-auto w-full object-cover',
          attributes: create_attribute({}),
        } only %}
      {% endif %}
    </figure>
  {% endif %}
  {% if title %}
    <h2 class="museothyssen-hello__title text-xl font-semibold tracking-tight text-slate-900">{{ title }}</h2>
  {% endif %}
  {% if subtitle %}
    <button
      type="button"
      class="museothyssen-hello__toggle mt-3 text-sm font-medium text-teal-700 underline-offset-2 hover:underline"
      data-hello-toggle
      aria-expanded="true"
      aria-controls="hello-subtitle-{{ attributes.id|default('default') }}"
    >
      {{ 'Toggle subtitle'|t }}
    </button>
    <p
      id="hello-subtitle-{{ attributes.id|default('default') }}"
      class="museothyssen-hello__subtitle mt-1 text-sm text-slate-600"
    >{{ subtitle }}</p>
  {% endif %}
  <section
    class="museothyssen-hello__pokeapi mt-4 border-t border-slate-200 pt-4"
    aria-label="{{ 'PokéAPI Ditto'|t }}"
  >
    <h3 class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-500">
      {{ 'PokéAPI: Ditto (clave = valor)'|t }}
    </h3>
    <pre
      class="max-h-96 overflow-auto rounded-lg bg-slate-50 p-3 font-mono text-xs leading-relaxed text-slate-800 ring-1 ring-inset ring-slate-200/80 whitespace-pre-wrap break-words"
      data-hello-ditto-json
    >{{ 'Cargando…'|t }}</pre>
  </section>
</div>
